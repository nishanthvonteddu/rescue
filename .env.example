# Disruption Rescue — shared env. Copy to `.env` and fill in from the hackathon
# dashboard. This file (`.env.example`) is committed; `.env` is git-ignored.

# ── Person 2: Voice (Vocal Bridge) ────────────────────────────────────────────
# "mock" = scripted-transcript fallback (demo-safe default). "real" = live call.
VOICE_MODE=mock
# If a real call fails, auto-run the scripted fallback so the flow still completes.
VOICE_AUTO_FALLBACK=true
# Optional: ms to keep the mock in "calling" before flipping to "picked" (0 = instant).
VOICE_MOCK_DELAY_MS=0

# Public HTTPS base URL Vocal Bridge's submit_choice tool calls back into.
# `npm run voice:tunnel` starts a Cloudflare quick tunnel and fills this in
# (and re-syncs the hosted agent). No trailing slash.
PUBLIC_BASE_URL=

# Optional shared secret for the public webhook. When set, the hosted agent's
# tool URL carries ?token=… and /api/voice/webhook rejects anything else.
# After setting it, run `npm run voice:sync` (or just place a call — the
# preflight auto-syncs).
VOICE_WEBHOOK_TOKEN=

# Vocal Bridge (agent-centric; the app shells out to the `vb` CLI for real calls).
VOCAL_BRIDGE_API_KEY=            # vb_... (agent- or account-scoped)
VOCAL_BRIDGE_BASE_URL=https://vocalbridgeai.com
VOCAL_BRIDGE_AGENT_ID=          # from `vocalbridge/setup-agent.sh` (required for account keys)
VOCAL_BRIDGE_CLI=vb             # path to the vb binary (override if in a venv)

# Demo traveler (used by /lib/mocks.ts). Set phone to YOUR number to test the call.
DEMO_TRAVELER_PHONE=+14155550123
DEMO_TRAVELER_PAYPAL=sb-buyer@example.com

# ── Agent mode: Gemini orchestrator (free-tier keys) ──────────────────────────
# 3-4 free AI Studio keys, comma-separated — the agent round-robins them and
# puts a key on cooldown when it hits its free-tier rate limit.
GEMINI_API_KEYS=key1,key2,key3
# Optional overrides:
GEMINI_MODEL=gemini-flash-latest   # the alias all free-tier projects can use
GEMINI_TURN_DELAY_MS=2500          # pause between model turns (free-tier RPM)

# ── Person 3 fills in LandingAI + PayPal keys here too (shared .env) ───────────

# ── Sabre (live flight search; seat maps need product entitlement) ────────────
SABRE_ACCESS_TOKEN=              # pre-issued bearer token, or use client id/secret:
SABRE_CLIENT_ID=
SABRE_CLIENT_SECRET=
SABRE_BASE_URL=https://api.cert.platform.sabre.com
SABRE_PCC=
