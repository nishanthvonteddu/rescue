# Disruption Rescue — shared env. Copy to `.env` and fill in from the hackathon
# dashboard. This file (`.env.example`) is committed; `.env` is git-ignored.

# ── Person 2: Voice (Vocal Bridge) ────────────────────────────────────────────
# Leave VOICE_MODE=mock for a demo-safe default; flip to `real` for a live call.
VOICE_MODE=mock
# If a real call fails, auto-run the scripted fallback so the flow still completes.
VOICE_AUTO_FALLBACK=true
# Optional: ms to keep the mock in "calling" before flipping to "picked" (0 = instant).
VOICE_MOCK_DELAY_MS=0

# Public HTTPS base URL Vocal Bridge tool-calls back into (your `ngrok http 3000`).
# e.g. https://abcd-1234.ngrok-free.app  — no trailing slash.
PUBLIC_BASE_URL=

# Vocal Bridge credentials + wire config (adjust names/paths to the real docs).
VOCAL_BRIDGE_API_KEY=
VOCAL_BRIDGE_BASE_URL=https://api.vocalbridge.ai
VOCAL_BRIDGE_CALL_PATH=/v1/calls
VOCAL_BRIDGE_FROM=
VOCAL_BRIDGE_AGENT_ID=
VOCAL_BRIDGE_VOICE=default
# Auth header/scheme — defaults suit a Bearer token; some APIs use x-api-key.
VOCAL_BRIDGE_AUTH_HEADER=Authorization
VOCAL_BRIDGE_AUTH_SCHEME=Bearer

# Demo traveler (used by /lib/mocks.ts). Set phone to YOUR number to test the call.
DEMO_TRAVELER_PHONE=+14155550123
DEMO_TRAVELER_PAYPAL=sb-buyer@example.com

# ── Person 3 fills in LandingAI + PayPal keys here too (shared .env) ───────────
